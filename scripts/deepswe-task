#!/usr/bin/env python3
"""Local human workflow helper for DeepSWE Harbor tasks."""

from __future__ import annotations

import argparse
import os
import shutil
import subprocess
import sys
import textwrap
from pathlib import Path

try:
    import tomllib
except ModuleNotFoundError:  # pragma: no cover - Python < 3.11 fallback.
    import tomli as tomllib  # type: ignore[no-redef]


ROOT = Path(__file__).resolve().parents[1]
TASKS_DIR = ROOT / "tasks"
WORKSPACES_DIR = ROOT / "workspaces"
PROXY_TOOLS = (
    "go",
    "gofmt",
    "goimports",
    "make",
    "pip",
    "pip3",
    "pytest",
    "python",
    "python3",
)
DEV_EXEC = "deepswe-exec"


class TaskError(RuntimeError):
    pass


def run(
    args: list[str],
    *,
    cwd: Path | None = None,
    check: bool = True,
    capture: bool = False,
    env: dict[str, str] | None = None,
) -> subprocess.CompletedProcess[str]:
    print("+ " + " ".join(str(a) for a in args))
    return subprocess.run(
        args,
        cwd=cwd,
        check=check,
        text=True,
        capture_output=capture,
        env=env,
    )


def load_task(task_id: str) -> tuple[Path, dict]:
    task_dir = TASKS_DIR / task_id
    task_toml = task_dir / "task.toml"
    if not task_toml.exists():
        raise TaskError(f"Task not found: {task_id} ({task_toml})")
    with task_toml.open("rb") as f:
        return task_dir, tomllib.load(f)


def task_workspace(task_id: str) -> Path:
    return WORKSPACES_DIR / task_id


def dev_container_name(task_id: str) -> str:
    safe = "".join(c if c.isalnum() or c in "_.-" else "-" for c in task_id)
    return f"deepswe-{safe}-dev"


def container_status(name: str) -> str | None:
    try:
        result = subprocess.run(
            ["docker", "inspect", "-f", "{{.State.Status}}", name],
            text=True,
            capture_output=True,
        )
    except FileNotFoundError:
        return None
    if result.returncode != 0:
        return None
    return result.stdout.strip() or None


def task_image(task_dir: Path, config: dict, task_id: str, force_build: bool) -> str:
    env_config = config.get("environment", {})
    prebuilt = env_config.get("docker_image")
    if prebuilt and not force_build:
        inspected = run(["docker", "image", "inspect", prebuilt], check=False, capture=True)
        if inspected.returncode != 0:
            run(["docker", "pull", prebuilt])
        return prebuilt

    image = f"deepswe-{task_id}:local"
    dockerfile = task_dir / "environment" / "Dockerfile"
    if not dockerfile.exists():
        raise TaskError(f"No prebuilt image and no Dockerfile at {dockerfile}")
    run(["docker", "build", "-t", image, str(dockerfile.parent)])
    return image


def write_workspace_notes(task_id: str, task_dir: Path, config: dict, workspace: Path) -> None:
    metadata = config.get("metadata", {})
    instruction = (task_dir / "instruction.md").read_text(encoding="utf-8")
    prompt = workspace / "PROMPT.md"
    prompt.write_text(instruction + "\n", encoding="utf-8")

    notes = workspace / "WORKSPACE.md"
    notes.write_text(
        textwrap.dedent(
            f"""\
            # {task_id}

            Repository: {metadata.get("repository_url", "unknown")}
            Base commit: {metadata.get("base_commit_hash", "unknown")}
            Language: {metadata.get("language", "unknown")}

            Editable source lives in:

            ```text
            {workspace / "app"}
            ```

            Useful commands from the DeepSWE repo root:

            ```bash
            scripts/deepswe-task code {task_id}
            scripts/deepswe-task codex {task_id}
            scripts/deepswe-task shell {task_id}
            scripts/deepswe-task verify {task_id}
            scripts/deepswe-task diff {task_id}
            ```

            To open over SSH from another machine:

            ```bash
            code --remote ssh-remote+<host> {workspace / "app"}
            ```
            """
        ),
        encoding="utf-8",
    )


def copy_app_from_image(image: str, app_dir: Path) -> None:
    container_id = run(["docker", "create", image], capture=True).stdout.strip()
    try:
        app_dir.mkdir(parents=True, exist_ok=True)
        run(["docker", "cp", f"{container_id}:/app/.", str(app_dir)])
    finally:
        run(["docker", "rm", container_id], check=False)


def copy_app_from_git(config: dict, app_dir: Path) -> None:
    metadata = config.get("metadata", {})
    repo_url = metadata.get("repository_url")
    base = metadata.get("base_commit_hash")
    if not repo_url or not base:
        raise TaskError("Task metadata has no repository_url/base_commit_hash fallback")
    app_dir.parent.mkdir(parents=True, exist_ok=True)
    run(["git", "clone", repo_url, str(app_dir)])
    run(["git", "checkout", base], cwd=app_dir)
    run(["git", "submodule", "update", "--init", "--recursive"], cwd=app_dir, check=False)


def app_has_base_commit(app_dir: Path, config: dict) -> bool:
    base = config.get("metadata", {}).get("base_commit_hash")
    if not base:
        return True
    result = subprocess.run(
        ["git", "rev-parse", "--verify", f"{base}^{{commit}}"],
        cwd=app_dir,
        text=True,
        capture_output=True,
    )
    return result.returncode == 0


def cmd_setup(args: argparse.Namespace) -> None:
    task_dir, config = load_task(args.task)
    workspace = task_workspace(args.task)
    app_dir = workspace / "app"

    if app_dir.exists() and any(app_dir.iterdir()):
        if not args.reset:
            raise TaskError(
                f"{app_dir} already exists. Re-run with --reset to recreate it."
            )
        shutil.rmtree(app_dir)

    workspace.mkdir(parents=True, exist_ok=True)
    image = "unavailable"
    try:
        image = task_image(task_dir, config, args.task, args.force_build)
        copy_app_from_image(image, app_dir)
    except subprocess.CalledProcessError:
        if args.force_build:
            raise
        print("Docker image setup failed; cloning task repository instead.")
        if app_dir.exists():
            shutil.rmtree(app_dir)
        copy_app_from_git(config, app_dir)

    if not app_has_base_commit(app_dir, config) and not args.force_build:
        print("Copied /app is not a valid git checkout for this task; cloning upstream.")
        shutil.rmtree(app_dir)
        copy_app_from_git(config, app_dir)
    if not app_has_base_commit(app_dir, config):
        raise TaskError(
            "Workspace was created, but the task base commit is not present in /app."
        )
    write_workspace_notes(args.task, task_dir, config, workspace)

    print()
    print(f"Workspace ready: {app_dir}")
    print(f"Prompt:          {workspace / 'PROMPT.md'}")
    print(f"Image:           {image}")


def require_workspace(task_id: str) -> tuple[Path, Path, Path, dict]:
    task_dir, config = load_task(task_id)
    workspace = task_workspace(task_id)
    app_dir = workspace / "app"
    if not app_dir.exists():
        raise TaskError(f"Workspace missing. Run: scripts/deepswe-task setup {task_id}")
    return task_dir, workspace, app_dir, config


def container_workdir(app_dir: Path) -> str:
    try:
        relative = Path.cwd().resolve().relative_to(app_dir.resolve())
    except ValueError:
        return "/app"
    if relative == Path("."):
        return "/app"
    return f"/app/{relative.as_posix()}"


def proxy_bin_dir(workspace: Path) -> Path:
    return workspace / ".bin"


def ensure_tool_proxies(
    task_id: str,
    task_dir: Path,
    workspace: Path,
    app_dir: Path,
    config: dict,
    *,
    force_build: bool = False,
) -> Path:
    image = task_image(task_dir, config, task_id, force_build)
    env_config = config.get("environment", {})
    platform_args = (
        '"--platform" "linux/amd64"'
        if env_config.get("docker_image") and not force_build
        else ""
    )
    bin_dir = proxy_bin_dir(workspace)
    cache_dir = workspace / ".cache" / "docker-tools"
    bin_dir.mkdir(parents=True, exist_ok=True)
    cache_dir.mkdir(parents=True, exist_ok=True)

    app = app_dir.resolve().as_posix()
    cache = cache_dir.resolve().as_posix()
    script = textwrap.dedent(
        f"""\
        #!/usr/bin/env bash
        set -euo pipefail

        APP_DIR={app!r}
        CACHE_DIR={cache!r}
        IMAGE={image!r}
        DOCKER_PLATFORM_ARGS=({platform_args})
        TOOL="$(basename "$0")"
        DOCKER_RUN=(docker run --rm)
        if ((${{#DOCKER_PLATFORM_ARGS[@]}})); then
          DOCKER_RUN+=("${{DOCKER_PLATFORM_ARGS[@]}}")
        fi

        mkdir -p "$CACHE_DIR/go" "$CACHE_DIR/go-build" "$CACHE_DIR/home" "$CACHE_DIR/pip" "$CACHE_DIR/tmp"

        case "$PWD" in
          "$APP_DIR"/*|"$APP_DIR")
            WORKDIR="$PWD"
            ;;
          *)
            WORKDIR="$APP_DIR"
            ;;
        esac

        exec "${{DOCKER_RUN[@]}}" \\
          --user "$(id -u):$(id -g)" \\
          -e HOME="$CACHE_DIR/home" \\
          -e GOPATH="$CACHE_DIR/go" \\
          -e GOMODCACHE="$CACHE_DIR/go/pkg/mod" \\
          -e GOCACHE="$CACHE_DIR/go-build" \\
          -e PIP_CACHE_DIR="$CACHE_DIR/pip" \\
          -e TMPDIR="$CACHE_DIR/tmp" \\
          -v "$APP_DIR:$APP_DIR" \\
          -v "$APP_DIR:/app" \\
          -v "$CACHE_DIR:$CACHE_DIR" \\
          -w "$WORKDIR" \\
          "$IMAGE" "$TOOL" "$@"
        """
    )
    for tool in PROXY_TOOLS:
        path = bin_dir / tool
        path.write_text(script, encoding="utf-8")
        path.chmod(0o755)
    return bin_dir


def ensure_dev_exec_wrapper(task_id: str, workspace: Path) -> Path:
    bin_dir = proxy_bin_dir(workspace)
    bin_dir.mkdir(parents=True, exist_ok=True)
    helper = ROOT / "scripts" / "deepswe-task"
    path = bin_dir / DEV_EXEC
    path.write_text(
        textwrap.dedent(
            f"""\
            #!/usr/bin/env bash
            set -euo pipefail

            exec {str(helper)!r} exec {task_id!r} -- "$@"
            """
        ),
        encoding="utf-8",
    )
    path.chmod(0o755)
    return bin_dir


def cmd_code(args: argparse.Namespace) -> None:
    _, _, app_dir, _ = require_workspace(args.task)
    code = shutil.which("code")
    if code is None:
        print(f"VS Code CLI not found. Open this folder manually:\n{app_dir}")
        return
    run([code, str(app_dir)], check=False)


def resolve_patch_path(patch_arg: str) -> Path:
    path = Path(patch_arg).expanduser()
    if not path.is_absolute():
        path = (Path.cwd() / path).resolve()
    if path.is_dir():
        path = path / "artifacts" / "model.patch"
    if not path.exists():
        raise TaskError(f"Patch not found: {path}")
    if not path.is_file():
        raise TaskError(f"Patch path is not a file: {path}")
    return path


def cmd_apply_patch(args: argparse.Namespace) -> None:
    _, _, app_dir, _ = require_workspace(args.task)
    patch = resolve_patch_path(args.patch)

    check_cmd = ["git", "apply", "--check"]
    apply_cmd = ["git", "apply"]
    if args.threeway:
        check_cmd.append("--3way")
        apply_cmd.append("--3way")
    check_cmd.append(str(patch))
    apply_cmd.append(str(patch))

    run(check_cmd, cwd=app_dir)
    run(apply_cmd, cwd=app_dir)
    print()
    print(f"Applied patch: {patch}")
    print(f"Workspace:     {app_dir}")


def cmd_up(args: argparse.Namespace) -> None:
    task_dir, workspace, app_dir, config = require_workspace(args.task)
    name = ensure_dev_container(
        args.task,
        task_dir,
        workspace,
        app_dir,
        config,
        force_build=args.force_build,
        recreate=args.recreate,
    )
    ensure_dev_exec_wrapper(args.task, workspace)
    print(f"Dev container running: {name}")
    print(f"Workspace mounted:     {app_dir} -> /app")
    print(f"Run commands with:     scripts/deepswe-task exec {args.task} -- <command>")


def cmd_exec(args: argparse.Namespace) -> None:
    task_dir, workspace, app_dir, config = require_workspace(args.task)
    command = list(args.command)
    if command and command[0] == "--":
        command = command[1:]
    if not command:
        raise TaskError(
            "Missing command. Example: scripts/deepswe-task exec <task> -- go test ./..."
        )
    name = ensure_dev_container(
        args.task,
        task_dir,
        workspace,
        app_dir,
        config,
        force_build=args.force_build,
    )
    result = run(
        ["docker", "exec", "-w", container_workdir(app_dir), name, *command],
        check=False,
    )
    sys.exit(result.returncode)


def cmd_down(args: argparse.Namespace) -> None:
    name = dev_container_name(args.task)
    status = container_status(name)
    if status is None:
        print(f"No dev container found: {name}")
        return
    run(["docker", "rm", "-f", name], check=False)
    print(f"Removed dev container: {name}")


def cmd_codex(args: argparse.Namespace) -> None:
    task_dir, workspace, app_dir, config = require_workspace(args.task)
    codex = shutil.which("codex")
    if codex is None:
        raise TaskError("codex CLI not found on PATH")

    sandbox = "danger-full-access" if args.allow_docker else args.sandbox
    print(f"Starting Codex in {app_dir}")
    print(f"Task prompt: {workspace / 'PROMPT.md'}")
    if args.allow_docker:
        print("Docker access: enabled via Codex danger-full-access sandbox")
    prompt = (workspace / "PROMPT.md").read_text(encoding="utf-8")
    if not args.no_dev_container:
        name = ensure_dev_container(
            args.task,
            task_dir,
            workspace,
            app_dir,
            config,
            force_build=args.force_build,
        )
        print(f"Dev container: {name}")
        prompt = textwrap.dedent(
            f"""\
            Local workflow note:
            - You are running on the host so Codex auth stays outside Docker.
            - Edit files directly in this workspace.
            - Run project commands inside the task container with `{DEV_EXEC} <command>`.
            - Examples: `{DEV_EXEC} go test ./...`, `{DEV_EXEC} make test`, `{DEV_EXEC} bash -lc 'pytest -q'`.
            - Do not run project build/test commands directly on the host unless explicitly asked.

            """
        ) + prompt
    cmd = [
        codex,
        "-m",
        args.model,
        "--sandbox",
        sandbox,
        "--ask-for-approval",
        args.approval,
    ]
    if args.exec:
        cmd = [
            codex,
            "exec",
            "-m",
            args.model,
            "--sandbox",
            sandbox,
            "--skip-git-repo-check",
            prompt,
        ]
    elif not args.no_prompt:
        cmd.append(prompt)

    env = os.environ.copy()
    if args.no_dev_container and not args.no_proxy_tools:
        bin_dir = ensure_tool_proxies(
            args.task,
            task_dir,
            workspace,
            app_dir,
            config,
            force_build=args.force_build,
        )
        env["PATH"] = f"{bin_dir}{os.pathsep}{env.get('PATH', '')}"
        print(f"Docker tool proxies: {bin_dir}")
    elif not args.no_dev_container:
        bin_dir = ensure_dev_exec_wrapper(args.task, workspace)
        env["PATH"] = f"{bin_dir}{os.pathsep}{env.get('PATH', '')}"
        print(f"Docker exec wrapper: {bin_dir / DEV_EXEC}")
    run(cmd, cwd=app_dir, check=False, env=env)


def docker_run_base(
    task_id: str,
    task_dir: Path,
    workspace: Path,
    app_dir: Path,
    config: dict,
    *,
    force_build: bool = False,
) -> list[str]:
    image = task_image(task_dir, config, task_id, force_build)
    logs_dir = workspace / "logs"
    for child in ("agent", "artifacts", "verifier"):
        (logs_dir / child).mkdir(parents=True, exist_ok=True)

    return [
        "docker",
        "run",
        "--rm",
        "--user",
        f"{os.getuid()}:{os.getgid()}",
        "-e",
        "HOME=/tmp",
        "-e",
        "GOPATH=/tmp/deepswe-go",
        "-e",
        "GOMODCACHE=/tmp/deepswe-go/pkg/mod",
        "-e",
        "GOCACHE=/tmp/deepswe-go-build",
        "-e",
        "TMPDIR=/tmp",
        "-v",
        f"{app_dir}:/app",
        "-v",
        f"{task_dir / 'tests'}:/tests:ro",
        "-v",
        f"{logs_dir / 'agent'}:/logs/agent",
        "-v",
        f"{logs_dir / 'artifacts'}:/logs/artifacts",
        "-v",
        f"{logs_dir / 'verifier'}:/logs/verifier",
        "-w",
        "/app",
        image,
    ]


def ensure_dev_container(
    task_id: str,
    task_dir: Path,
    workspace: Path,
    app_dir: Path,
    config: dict,
    *,
    force_build: bool = False,
    recreate: bool = False,
) -> str:
    name = dev_container_name(task_id)
    status = container_status(name)

    if status and recreate:
        run(["docker", "rm", "-f", name], check=False)
        status = None

    if status == "running":
        return name
    if status:
        run(["docker", "start", name])
        return name

    base = docker_run_base(
        task_id,
        task_dir,
        workspace,
        app_dir,
        config,
        force_build=force_build,
    )
    image = base[-1]
    create_cmd = [
        "docker",
        "create",
        "--name",
        name,
        *base[3:-1],
        image,
        "sleep",
        "infinity",
    ]
    run(create_cmd)
    run(["docker", "start", name])
    return name


def cmd_shell(args: argparse.Namespace) -> None:
    task_dir, workspace, app_dir, config = require_workspace(args.task)
    cmd = docker_run_base(
        args.task,
        task_dir,
        workspace,
        app_dir,
        config,
        force_build=args.force_build,
    )
    run(cmd[:2] + ["-it"] + cmd[2:] + ["/bin/bash"], check=False)


def clean_dir(path: Path) -> None:
    if path.exists():
        shutil.rmtree(path)
    path.mkdir(parents=True, exist_ok=True)


def cmd_verify(args: argparse.Namespace) -> None:
    task_dir, workspace, app_dir, config = require_workspace(args.task)
    verify_root = workspace / ".verify-run"
    verify_app = verify_root / "app"

    clean_dir(verify_root)
    shutil.copytree(app_dir, verify_app, symlinks=True)

    logs_dir = workspace / "logs"
    for child in ("artifacts", "verifier"):
        clean_dir(logs_dir / child)
    (logs_dir / "agent").mkdir(parents=True, exist_ok=True)

    cmd = docker_run_base(
        args.task,
        task_dir,
        workspace,
        verify_app,
        config,
        force_build=args.force_build,
    )
    result = run(cmd + ["bash", "/tests/test.sh"], check=False)

    reward = logs_dir / "verifier" / "reward.txt"
    if reward.exists():
        print(f"\nReward: {reward.read_text(encoding='utf-8').strip()}")
    else:
        print("\nNo reward file written.")
    write_model_patch(workspace, app_dir, config)
    print(f"Verifier log dir: {logs_dir / 'verifier'}")
    print(f"Model patch:      {logs_dir / 'artifacts' / 'model.patch'}")
    sys.exit(result.returncode)


def write_model_patch(workspace: Path, app_dir: Path, config: dict) -> Path:
    base = config.get("metadata", {}).get("base_commit_hash")
    if not base:
        raise TaskError("Task metadata has no base_commit_hash")
    artifacts_dir = workspace / "logs" / "artifacts"
    artifacts_dir.mkdir(parents=True, exist_ok=True)
    patch_path = artifacts_dir / "model.patch"
    result = run(["git", "diff", "--binary", base], cwd=app_dir, capture=True)
    patch_path.write_text(result.stdout, encoding="utf-8")
    if result.stdout.strip():
        print(f"Patch written:    {patch_path}")
    else:
        print(f"Patch written:    {patch_path} (empty)")
    return patch_path


def cmd_interactive(args: argparse.Namespace) -> None:
    workspace = task_workspace(args.task)
    app_dir = workspace / "app"
    workspace_missing = not app_dir.exists() or not any(app_dir.iterdir())
    if args.reset or workspace_missing:
        setup_args = argparse.Namespace(
            task=args.task,
            reset=args.reset,
            force_build=args.force_build,
        )
        cmd_setup(setup_args)

    task_dir, workspace, app_dir, config = require_workspace(args.task)
    codex_args = argparse.Namespace(
        task=args.task,
        model=args.model,
        sandbox=args.sandbox,
        approval=args.approval,
        exec=False,
        no_prompt=args.no_prompt,
        no_proxy_tools=args.no_proxy_tools,
        no_dev_container=args.no_dev_container,
        allow_docker=args.allow_docker,
        force_build=args.force_build,
    )
    cmd_codex(codex_args)

    if args.no_verify:
        write_model_patch(workspace, app_dir, config)
        print("Verifier skipped.")
        return

    verify_args = argparse.Namespace(task=args.task, force_build=args.force_build)
    cmd_verify(verify_args)


def cmd_diff(args: argparse.Namespace) -> None:
    _, _, app_dir, config = require_workspace(args.task)
    base = config.get("metadata", {}).get("base_commit_hash")
    if not base:
        raise TaskError("Task metadata has no base_commit_hash")
    run(["git", "diff", "--binary", base], cwd=app_dir, check=False)


def cmd_status(args: argparse.Namespace) -> None:
    task_dir, workspace, app_dir, config = require_workspace(args.task)
    image = config.get("environment", {}).get("docker_image", "local build")
    name = dev_container_name(args.task)
    print(f"Task:          {task_dir}")
    print(f"Workspace:     {workspace}")
    print(f"App:           {app_dir}")
    print(f"Image:         {image}")
    print(f"Dev container: {name} ({container_status(name) or 'missing'})")
    run(["git", "status", "--short", "--branch"], cwd=app_dir, check=False)


def cmd_proxy_tools(args: argparse.Namespace) -> None:
    task_dir, workspace, app_dir, config = require_workspace(args.task)
    bin_dir = ensure_tool_proxies(
        args.task,
        task_dir,
        workspace,
        app_dir,
        config,
        force_build=args.force_build,
    )
    print(f"Proxy tools ready: {bin_dir}")
    print()
    print("For a manual terminal session, run:")
    print(f"export PATH={bin_dir}:$PATH")
    print()
    print("Then commands like `go env GOPATH`, `make test`, and `pytest -q` run in Docker.")


def cmd_dev_exec(args: argparse.Namespace) -> None:
    _, workspace, _, _ = require_workspace(args.task)
    bin_dir = ensure_dev_exec_wrapper(args.task, workspace)
    print(f"Dev exec wrapper ready: {bin_dir / DEV_EXEC}")
    print()
    print("For a manual terminal session, run:")
    print(f"export PATH={bin_dir}:$PATH")
    print()
    print(f"Then commands like `{DEV_EXEC} go test ./...` run in the persistent task container.")


def cmd_ssh_code(args: argparse.Namespace) -> None:
    _, _, app_dir, _ = require_workspace(args.task)
    print(f"code --remote ssh-remote+{args.host} {app_dir}")


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        description="Create, edit, and verify local DeepSWE task workspaces."
    )
    sub = parser.add_subparsers(dest="command", required=True)

    setup = sub.add_parser("setup", help="Create workspaces/<task>/app from image /app")
    setup.add_argument("task")
    setup.add_argument("--reset", action="store_true", help="Recreate an existing app tree")
    setup.add_argument("--force-build", action="store_true", help="Build task image locally")
    setup.set_defaults(func=cmd_setup)

    code = sub.add_parser("code", help="Open the task app folder in VS Code")
    code.add_argument("task")
    code.set_defaults(func=cmd_code)

    apply_patch = sub.add_parser(
        "apply-patch",
        help="Apply a model.patch file or trial directory to the task workspace",
    )
    apply_patch.add_argument("task")
    apply_patch.add_argument(
        "patch",
        help="Path to model.patch, or a trial directory containing artifacts/model.patch",
    )
    apply_patch.add_argument(
        "--3way",
        dest="threeway",
        action="store_true",
        help="Use git apply --3way when checking and applying",
    )
    apply_patch.set_defaults(func=cmd_apply_patch)

    up = sub.add_parser("up", help="Start the persistent task dev container")
    up.add_argument("task")
    up.add_argument("--force-build", action="store_true")
    up.add_argument("--recreate", action="store_true", help="Replace an existing dev container")
    up.set_defaults(func=cmd_up)

    exec_parser = sub.add_parser(
        "exec",
        help="Run a command in the persistent task dev container",
    )
    exec_parser.add_argument("task")
    exec_parser.add_argument("--force-build", action="store_true")
    exec_parser.add_argument("command", nargs=argparse.REMAINDER)
    exec_parser.set_defaults(func=cmd_exec)

    down = sub.add_parser("down", help="Stop and remove the persistent task dev container")
    down.add_argument("task")
    down.set_defaults(func=cmd_down)

    codex = sub.add_parser("codex", help="Launch Codex in the task app folder")
    codex.add_argument("task")
    codex.add_argument(
        "--model",
        default=os.environ.get("DEEPSWE_CODEX_MODEL", "gpt-5.5"),
        help="Codex model to use (default: DEEPSWE_CODEX_MODEL or gpt-5.5)",
    )
    codex.add_argument(
        "--sandbox",
        default="workspace-write",
        choices=["read-only", "workspace-write", "danger-full-access"],
        help="Codex sandbox mode for editing",
    )
    codex.add_argument(
        "--approval",
        default="on-request",
        choices=["untrusted", "on-failure", "on-request", "never"],
        help="Interactive approval policy",
    )
    codex.add_argument(
        "--exec",
        action="store_true",
        help="Run codex exec non-interactively with PROMPT.md",
    )
    codex.add_argument(
        "--no-prompt",
        action="store_true",
        help="Start interactive Codex without sending PROMPT.md first",
    )
    codex.add_argument(
        "--no-proxy-tools",
        action="store_true",
        help="Do not prepend legacy Docker-backed go/make wrappers to PATH",
    )
    codex.add_argument(
        "--no-dev-container",
        action="store_true",
        help="Use legacy per-tool docker run wrappers instead of the persistent dev container",
    )
    codex.add_argument(
        "--allow-docker",
        action="store_true",
        help="Let Docker-backed tool wrappers run without Codex sandbox denial",
    )
    codex.add_argument("--force-build", action="store_true")
    codex.set_defaults(func=cmd_codex)

    interactive = sub.add_parser(
        "interactive",
        help="Setup if needed, run interactive Codex, write patch, then verify",
    )
    interactive.add_argument("task")
    interactive.add_argument(
        "--model",
        default=os.environ.get("DEEPSWE_CODEX_MODEL", "gpt-5.5"),
        help="Codex model to use (default: DEEPSWE_CODEX_MODEL or gpt-5.5)",
    )
    interactive.add_argument(
        "--sandbox",
        default="workspace-write",
        choices=["read-only", "workspace-write", "danger-full-access"],
        help="Codex sandbox mode for editing",
    )
    interactive.add_argument(
        "--approval",
        default="on-request",
        choices=["untrusted", "on-failure", "on-request", "never"],
        help="Interactive approval policy",
    )
    interactive.add_argument(
        "--no-prompt",
        action="store_true",
        help="Start interactive Codex without sending PROMPT.md first",
    )
    interactive.add_argument(
        "--no-proxy-tools",
        action="store_true",
        help="Do not prepend legacy Docker-backed tool wrappers to PATH",
    )
    interactive.add_argument(
        "--no-dev-container",
        action="store_true",
        help="Use legacy per-tool docker run wrappers instead of the persistent dev container",
    )
    interactive.add_argument(
        "--allow-docker",
        action="store_true",
        help="Let Docker-backed tool wrappers run without Codex sandbox denial",
    )
    interactive.add_argument(
        "--no-verify",
        action="store_true",
        help="Write the patch but skip verifier execution",
    )
    interactive.add_argument(
        "--reset",
        action="store_true",
        help="Recreate the workspace before starting Codex",
    )
    interactive.add_argument("--force-build", action="store_true")
    interactive.set_defaults(func=cmd_interactive)

    shell = sub.add_parser("shell", help="Open an interactive shell in the task image")
    shell.add_argument("task")
    shell.add_argument("--force-build", action="store_true")
    shell.set_defaults(func=cmd_shell)

    verify = sub.add_parser("verify", help="Run the task verifier against a copy")
    verify.add_argument("task")
    verify.add_argument("--force-build", action="store_true")
    verify.set_defaults(func=cmd_verify)

    diff = sub.add_parser("diff", help="Print a binary git diff from the task base commit")
    diff.add_argument("task")
    diff.set_defaults(func=cmd_diff)

    status = sub.add_parser("status", help="Show workspace paths and git status")
    status.add_argument("task")
    status.set_defaults(func=cmd_status)

    proxy_tools = sub.add_parser(
        "proxy-tools",
        help="Create legacy Docker-backed project tool wrappers",
    )
    proxy_tools.add_argument("task")
    proxy_tools.add_argument("--force-build", action="store_true")
    proxy_tools.set_defaults(func=cmd_proxy_tools)

    dev_exec = sub.add_parser(
        "dev-exec",
        help=f"Create the {DEV_EXEC} wrapper for the persistent task dev container",
    )
    dev_exec.add_argument("task")
    dev_exec.set_defaults(func=cmd_dev_exec)

    ssh_code = sub.add_parser("ssh-code", help="Print a VS Code Remote SSH command")
    ssh_code.add_argument("task")
    ssh_code.add_argument("host")
    ssh_code.set_defaults(func=cmd_ssh_code)

    return parser


def main() -> None:
    parser = build_parser()
    args = parser.parse_args()
    try:
        args.func(args)
    except TaskError as exc:
        print(f"error: {exc}", file=sys.stderr)
        sys.exit(2)


if __name__ == "__main__":
    main()
